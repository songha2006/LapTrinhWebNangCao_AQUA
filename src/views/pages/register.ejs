<div class="max-w-md mx-auto px-4 py-14">
  <div class="bg-white rounded-3xl border border-stone-200 p-8">
    <h1 class="text-2xl font-bold tracking-tight text-center">Tạo tài khoản</h1>
    <p class="text-sm text-stone-500 text-center mt-1 mb-6">Nhận mã WELCOME10 giảm 10% cho đơn đầu tiên</p>

    <% if (errors.length) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 mb-5 text-sm">
        <ul class="list-disc list-inside space-y-0.5">
          <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
        </ul>
      </div>
    <% } %>

    <form action="/register" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium mb-1.5" for="name">Họ tên</label>
        <input id="name" type="text" name="name" required minlength="2" value="<%= old.name || '' %>"
               class="w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm outline-none focus:border-brand-500">
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5" for="email">Email</label>
        <input id="email" type="email" name="email" required value="<%= old.email || '' %>"
               class="w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm outline-none focus:border-brand-500">
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5" for="phone">Số điện thoại (tùy chọn)</label>
        <input id="phone" type="tel" name="phone" pattern="^0\d{9,10}$" value="<%= old.phone || '' %>" placeholder="0912345678"
               class="w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm outline-none focus:border-brand-500">
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5" for="password">Mật khẩu</label>
        <input id="password" type="password" name="password" required minlength="6"
               class="w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm outline-none focus:border-brand-500">
        <p class="text-xs text-stone-400 mt-1">Tối thiểu 6 ký tự</p>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5" for="password_confirm">Xác nhận mật khẩu</label>
        <input id="password_confirm" type="password" name="password_confirm" required minlength="6"
               class="w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm outline-none focus:border-brand-500">
      </div>
      <button class="w-full py-3 rounded-full bg-brand-600 text-white font-semibold hover:bg-brand-700 active:scale-[0.98] transition">Đăng ký</button>
    </form>

    <p class="text-sm text-stone-500 text-center mt-6">
      Đã có tài khoản? <a href="/login" class="text-brand-600 font-medium hover:underline">Đăng nhập</a>
    </p>
  </div>
</div>
