<div class="max-w-md mx-auto px-4 py-14">
  <div class="bg-white rounded-3xl border border-stone-200 p-8">
    <h1 class="text-2xl font-bold tracking-tight text-center">Đăng nhập</h1>
    <p class="text-sm text-stone-500 text-center mt-1 mb-6">Chào mừng bạn quay lại AQUA</p>

    <% if (errors.length) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 mb-5 text-sm">
        <% errors.forEach(e => { %><p><%= e.msg %></p><% }) %>
      </div>
    <% } %>

    <form action="/login" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-medium mb-1.5" for="email">Email</label>
        <input id="email" type="email" name="email" required value="<%= old.email || '' %>"
               class="w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm outline-none focus:border-brand-500">
      </div>
      <div>
        <label class="block text-sm font-medium mb-1.5" for="password">Mật khẩu</label>
        <input id="password" type="password" name="password" required
               class="w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm outline-none focus:border-brand-500">
      </div>
      <div class="text-right">
        <a href="/forgot-password" class="text-sm text-brand-600 hover:underline">Quên mật khẩu?</a>
      </div>
      <button class="w-full py-3 rounded-full bg-brand-600 text-white font-semibold hover:bg-brand-700 active:scale-[0.98] transition">Đăng nhập</button>
    </form>

    <p class="text-sm text-stone-500 text-center mt-6">
      Chưa có tài khoản? <a href="/register" class="text-brand-600 font-medium hover:underline">Đăng ký ngay</a>
    </p>
  </div>
</div>
