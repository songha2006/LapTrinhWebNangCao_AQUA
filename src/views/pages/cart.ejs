<div class="max-w-5xl mx-auto px-4 py-8">
  <h1 class="text-2xl md:text-3xl font-bold tracking-tight mb-6">Giỏ hàng</h1>

  <% if (items.length === 0) { %>
    <div class="bg-white rounded-2xl border border-stone-200 py-20 text-center">
      <svg class="w-14 h-14 mx-auto text-stone-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M6 6h15l-1.5 8.5a2 2 0 0 1-2 1.5H8.7a2 2 0 0 1-2-1.6L5 3H2"/><circle cx="9" cy="20" r="1.5"/><circle cx="18" cy="20" r="1.5"/></svg>
      <p class="mt-4 font-semibold">Giỏ hàng của bạn đang trống</p>
      <p class="text-sm text-stone-500 mt-1">Khám phá hàng trăm mẫu bình giữ nhiệt chính hãng.</p>
      <a href="/products" class="inline-block mt-5 px-6 py-3 rounded-full bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700">Mua sắm ngay</a>
    </div>
  <% } else { %>
    <div class="grid lg:grid-cols-[1fr_320px] gap-8 items-start">
      <div class="bg-white rounded-2xl border border-stone-200 divide-y divide-stone-100">
        <% items.forEach(item => { %>
          <div class="flex gap-4 p-4">
            <a href="/products/<%= item.variant.Product.slug %>" class="w-24 h-24 shrink-0 rounded-xl overflow-hidden bg-stone-50 border border-stone-100">
              <img src="<%= item.variant.image || item.variant.Product.thumbnail %>" alt="" class="w-full h-full object-cover">
            </a>
            <div class="flex-1 min-w-0">
              <div class="flex justify-between gap-2">
                <a href="/products/<%= item.variant.Product.slug %>" class="font-semibold text-sm hover:text-brand-700 line-clamp-2"><%= item.variant.Product.name %></a>
                <form action="/cart/remove/<%= item.variant.id %>" method="POST">
                  <button class="text-stone-400 hover:text-red-500 p-1" title="Xóa">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 6h18M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>
                  </button>
                </form>
              </div>
              <p class="text-xs text-stone-500 mt-1 flex items-center gap-1.5">
                <span class="w-3 h-3 rounded-full inline-block border border-stone-200" style="background:<%= item.variant.color_code %>"></span>
                <%= item.variant.color %> &middot; <%= item.variant.capacity %>ml
              </p>
              <div class="flex items-center justify-between mt-2">
                <form action="/cart/update" method="POST" class="flex items-center rounded-full border border-stone-300 overflow-hidden">
                  <input type="hidden" name="variant_id" value="<%= item.variant.id %>">
                  <button name="qty" value="<%= item.qty - 1 %>" class="px-3 py-1.5 hover:bg-stone-100 text-sm font-bold">&minus;</button>
                  <span class="w-10 text-center text-sm font-medium"><%= item.qty %></span>
                  <button name="qty" value="<%= item.qty + 1 %>" class="px-3 py-1.5 hover:bg-stone-100 text-sm font-bold" <%= item.qty >= item.variant.stock ? 'disabled' : '' %>>+</button>
                </form>
                <p class="font-bold text-brand-700"><%= vnd(item.lineTotal) %></p>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <div class="bg-white rounded-2xl border border-stone-200 p-5 lg:sticky lg:top-32">
        <h2 class="font-semibold mb-4">Tóm tắt đơn hàng</h2>
        <div class="flex justify-between text-sm mb-2">
          <span class="text-stone-500">Tạm tính</span>
          <span class="font-medium"><%= vnd(subtotal) %></span>
        </div>
        <div class="flex justify-between text-sm mb-4">
          <span class="text-stone-500">Phí vận chuyển</span>
          <span class="font-medium text-brand-600">Miễn phí</span>
        </div>
        <div class="border-t border-stone-200 pt-3 flex justify-between items-center mb-5">
          <span class="font-semibold">Tổng cộng</span>
          <span class="text-xl font-extrabold text-brand-700"><%= vnd(subtotal) %></span>
        </div>
        <a href="/checkout" class="block w-full text-center py-3 rounded-full bg-accent-500 text-white font-semibold hover:bg-accent-600 active:scale-[0.98] transition shadow-lg shadow-accent-500/20">Tiến hành đặt hàng</a>
        <a href="/products" class="block w-full text-center py-3 mt-2 text-sm text-stone-500 hover:text-brand-600">Tiếp tục mua sắm</a>
      </div>
    </div>
  <% } %>
</div>
