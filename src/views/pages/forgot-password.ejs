<div class="max-w-md mx-auto px-4 py-14">
  <div class="bg-white rounded-3xl border border-stone-200 p-8">
    <h1 class="text-2xl font-bold tracking-tight text-center">Quên mật khẩu</h1>
    <p class="text-sm text-stone-500 text-center mt-1 mb-6">Nhập email để nhận link đặt lại mật khẩu</p>

    <% if (errors.length) { %>
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 mb-5 text-sm">
        <% errors.forEach(e => { %><p><%= e.msg %></p><% }) %>
      </div>
    <% } %>

    <% if (resetLink) { %>
      <div class="bg-brand-50 border border-brand-200 rounded-xl px-4 py-4 mb-5 text-sm">
        <p class="font-semibold text-brand-800 mb-2">Yêu cầu thành công!</p>
        <p class="text-stone-600 mb-3">Trong môi trường demo (không có máy chủ email), link đặt lại được hiển thị trực tiếp bên dưới. Link có hiệu lực 1 giờ.</p>
        <a href="<%= resetLink %>" class="inline-block px-4 py-2 rounded-full bg-brand-600 text-white font-semibold hover:bg-brand-700">Đặt lại mật khẩu</a>
      </div>
    <% } else { %>
      <form action="/forgot-password" method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium mb-1.5" for="email">Email đã đăng ký</label>
          <input id="email" type="email" name="email" required
                 class="w-full rounded-xl border border-stone-300 px-4 py-2.5 text-sm outline-none focus:border-brand-500">
        </div>
        <button class="w-full py-3 rounded-full bg-brand-600 text-white font-semibold hover:bg-brand-700">Gửi yêu cầu</button>
      </form>
    <% } %>

    <p class="text-sm text-stone-500 text-center mt-6">
      <a href="/login" class="text-brand-600 font-medium hover:underline">&larr; Quay lại đăng nhập</a>
    </p>
  </div>
</div>
