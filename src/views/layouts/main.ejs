<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | AQUA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            // Xanh pine đậm — màu thương hiệu
            brand: { 50:'#eef4f0',100:'#d7e6dd',200:'#b0ccbc',300:'#7faa92',400:'#4f886b',500:'#2f6b4e',600:'#245740',700:'#1d4634',800:'#193a2c',900:'#122a20' },
            // Cam đất — màu nhấn duy nhất
            accent: { 500:'#e2612f', 600:'#cf5223', 700:'#b0431b' },
            sand: '#f7f5f1',
            ink: '#1a1815',
          },
          fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'] },
          letterSpacing: { tightest: '-0.04em' },
        }
      }
    }
  </script>
  <style>
    html { scroll-behavior: smooth; }
    body { -webkit-font-smoothing: antialiased; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .u-blur { backdrop-filter: saturate(180%) blur(12px); -webkit-backdrop-filter: saturate(180%) blur(12px); }
  </style>
</head>
<body class="bg-sand text-ink font-sans flex flex-col min-h-[100dvh]">

  <!-- Announcement bar -->
  <div class="bg-brand-900 text-brand-50 text-[13px]">
    <div class="max-w-7xl mx-auto px-4 h-9 flex items-center justify-center gap-6 tracking-tight">
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-accent-500"></span>
        Miễn phí vận chuyển đơn từ 500.000₫
      </span>
      <span class="hidden sm:inline text-brand-200">Bảo hành chính hãng 12 tháng · Đổi trả trong 7 ngày</span>
    </div>
  </div>

  <!-- Header -->
  <header class="bg-white/85 u-blur border-b border-black/5 sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center gap-5 h-[68px]">
        <a href="/" class="flex items-center gap-2 shrink-0">
          <span class="grid place-items-center w-9 h-9 rounded-xl bg-brand-700 text-white">
            <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor" aria-hidden="true"><path d="M9 2h6v2.2c0 .6.2 1.2.6 1.7.9 1 1.4 2.4 1.4 3.8V19a3 3 0 0 1-3 3h-4a3 3 0 0 1-3-3V9.7c0-1.4.5-2.8 1.4-3.8.4-.5.6-1.1.6-1.7V2z"/></svg>
          </span>
          <span class="text-[22px] font-extrabold tracking-tightest">AQUA</span>
        </a>

        <form action="/products" method="GET" class="flex-1 max-w-xl hidden sm:flex">
          <div class="flex w-full rounded-full bg-sand border border-black/5 focus-within:border-brand-400 focus-within:bg-white transition overflow-hidden">
            <input type="text" name="q" value="<%= query.q || '' %>" placeholder="Tìm bình giữ nhiệt, ly, ca cốc..."
                   class="flex-1 px-5 py-2.5 text-sm outline-none bg-transparent placeholder:text-stone-400">
            <button class="px-4 text-stone-500 hover:text-brand-700" aria-label="Tìm kiếm">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
            </button>
          </div>
        </form>

        <nav class="ml-auto flex items-center gap-1">
          <% if (currentUser) { %>
            <% if (currentUser.role === 'admin') { %>
              <a href="/admin" class="hidden md:inline-block text-sm font-medium px-3 py-2 rounded-full hover:bg-sand">Quản trị</a>
            <% } %>
            <a href="/orders" class="hidden md:inline-block text-sm font-medium px-3 py-2 rounded-full hover:bg-sand">Đơn hàng</a>
            <form action="/logout" method="POST" class="inline">
              <button class="text-sm font-medium px-3 py-2 rounded-full hover:bg-sand text-stone-500" title="Đăng xuất <%= currentUser.name %>">Đăng xuất</button>
            </form>
          <% } else { %>
            <a href="/login" class="text-sm font-medium px-3 py-2 rounded-full hover:bg-sand">Đăng nhập</a>
            <a href="/register" class="hidden sm:inline-block text-sm font-semibold px-4 py-2 rounded-full bg-brand-700 text-white hover:bg-brand-800 transition">Đăng ký</a>
          <% } %>
          <a href="/cart" class="relative p-2.5 rounded-full hover:bg-sand ml-1" aria-label="Giỏ hàng">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M6 6h15l-1.5 8.5a2 2 0 0 1-2 1.5H8.7a2 2 0 0 1-2-1.6L5 3H2"/><circle cx="9" cy="20" r="1.5"/><circle cx="18" cy="20" r="1.5"/></svg>
            <% if (cartCount > 0) { %>
              <span class="absolute top-0.5 right-0.5 bg-accent-500 text-white text-[10px] font-bold rounded-full min-w-[18px] h-[18px] px-1 flex items-center justify-center"><%= cartCount %></span>
            <% } %>
          </a>
        </nav>
      </div>

      <!-- Danh mục -->
      <nav class="flex items-center gap-1 overflow-x-auto no-scrollbar -mx-1 pb-2.5 pt-0.5">
        <a href="/products" class="whitespace-nowrap text-[13px] font-medium px-3.5 py-1.5 rounded-full transition <%= currentPath === '/products' && !query.category ? 'bg-brand-700 text-white' : 'text-stone-600 hover:bg-sand' %>">Tất cả</a>
        <% navCategories.forEach(c => { %>
          <a href="/products?category=<%= c.slug %>" class="whitespace-nowrap text-[13px] font-medium px-3.5 py-1.5 rounded-full transition <%= query.category === c.slug ? 'bg-brand-700 text-white' : 'text-stone-600 hover:bg-sand' %>"><%= c.name %></a>
        <% }) %>
      </nav>
    </div>
  </header>

  <!-- Flash -->
  <% if (flash) { %>
    <div id="flash" class="fixed top-24 right-4 z-50 max-w-sm rounded-2xl shadow-xl shadow-black/10 px-4 py-3.5 text-sm font-medium text-white <%= flash.type === 'error' ? 'bg-accent-600' : 'bg-brand-700' %>">
      <%= flash.message %>
    </div>
    <script>setTimeout(() => { const f = document.getElementById('flash'); if (f) { f.style.transition = 'opacity .4s, transform .4s'; f.style.opacity = '0'; f.style.transform = 'translateY(-8px)'; setTimeout(() => f.remove(), 400); } }, 3200);</script>
  <% } %>

  <main class="flex-1">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="bg-brand-900 text-brand-100 mt-20">
    <div class="max-w-7xl mx-auto px-4 py-14 grid grid-cols-2 md:grid-cols-4 gap-8 text-sm">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <span class="grid place-items-center w-8 h-8 rounded-lg bg-brand-700 text-white">
            <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor" aria-hidden="true"><path d="M9 2h6v2.2c0 .6.2 1.2.6 1.7.9 1 1.4 2.4 1.4 3.8V19a3 3 0 0 1-3 3h-4a3 3 0 0 1-3-3V9.7c0-1.4.5-2.8 1.4-3.8.4-.5.6-1.1.6-1.7V2z"/></svg>
          </span>
          <span class="font-extrabold text-lg text-white tracking-tightest">AQUA</span>
        </div>
        <p class="text-brand-200 leading-relaxed max-w-xs">Bình giữ nhiệt chính hãng. Giữ trọn nhiệt độ, giữ trọn phong cách sống.</p>
      </div>
      <div>
        <h3 class="font-semibold text-white mb-4">Danh mục</h3>
        <ul class="space-y-2.5 text-brand-200">
          <% navCategories.forEach(c => { %>
            <li><a href="/products?category=<%= c.slug %>" class="hover:text-white transition"><%= c.name %></a></li>
          <% }) %>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold text-white mb-4">Hỗ trợ</h3>
        <ul class="space-y-2.5 text-brand-200">
          <li>Đổi trả trong 7 ngày</li>
          <li>Bảo hành chính hãng 12 tháng</li>
          <li>Giao hàng toàn quốc</li>
        </ul>
      </div>
      <div>
        <h3 class="font-semibold text-white mb-4">Liên hệ</h3>
        <ul class="space-y-2.5 text-brand-200">
          <li>Hotline: 1900 6868</li>
          <li>Email: hotro@aqua.vn</li>
        </ul>
      </div>
    </div>
    <div class="border-t border-white/10 py-5 text-center text-xs text-brand-300">© 2026 AQUA — Đồ án Lập trình web nâng cao</div>
  </footer>
</body>
</html>
