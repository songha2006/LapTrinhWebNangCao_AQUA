# Sao chép file này thành .env rồi điền thông tin:  cp .env.example .env
# (.env không được đẩy lên git để bảo mật)

# ===== Server =====
PORT=3000
SESSION_SECRET=doi-thanh-mot-chuoi-ngau-nhien-cua-ban

# ===== Database =====
# DB_DIALECT: sqlite (chạy ngay, không cần cài gì) | mysql (khi nộp đồ án)
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

DB_HOST=localhost
DB_PORT=3306
DB_NAME=binh_giu_nhiet
DB_USER=root
DB_PASS=

# ===== Ảnh sản phẩm (Pixabay) — tùy chọn =====
# Lấy key miễn phí tại https://pixabay.com/api/docs/  (để trống thì dùng ảnh SVG tự vẽ)
PIXABAY_KEY=

# ===== VNPay Sandbox — tùy chọn =====
# Đăng ký tại https://sandbox.vnpayment.vn/devreg/  (để trống thì dùng chế độ giả lập)
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:3000/payment/vnpay-return
